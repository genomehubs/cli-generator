{
  "query": {
    "index": "taxon",
    "taxa": ["Mammalia"],
    "taxon_filter_type": "tree"
  },
  "params": {
    "taxonomy": "ncbi"
  },
  "report": {
    "report": "scatter",
    "scatter_threshold": 10000,
    "axes": [
      { "field": "genome_size", "position": "cat", "scale": "log10" },
      { "field": "assembly_span", "position": "y", "scale": "log10" },
      {
        "field": "assembly_level",
        "position": "x",
        "bin_count": 2,
        "show_other": true
      }
    ]
  }
}
