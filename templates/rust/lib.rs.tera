        Err(e) => {% raw %}format!(r#"{{"error":{e:?}}}"#){% endraw %},
    }
}

/// Validate a query against field metadata and configuration.
///
/// Returns a JSON array of error strings. An empty array means the query is valid.
#[cfg(feature = "extension-module")]
#[pyfunction]
fn validate_query_json(
    query_yaml: &str,
    field_metadata_json: &str,
    validation_config_json: &str,
    synonyms_json: &str,
) -> String {
    use crate::embedded::core::validation;
    validation::validate_query_json(
        query_yaml,
        field_metadata_json,
        validation_config_json,
        synonyms_json,
    )
}

