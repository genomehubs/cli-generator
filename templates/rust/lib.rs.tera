    m.add_function(wrap_pyfunction!(to_tidy_records, m)?)?;
    m.add_function(wrap_pyfunction!(parse_paginated_json, m)?)?;
    m.add_function(wrap_pyfunction!(validate_query_json, m)?)?;
    Ok(())
