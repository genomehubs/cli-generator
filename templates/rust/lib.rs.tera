/// Strip all `__*` sub-key columns, keeping identity columns and bare field values.
///
/// `keep_columns_json` is a JSON array of `__*` column names to preserve,
/// e.g. `'["assembly_span__min"]'`.  Pass `""` to strip all.
/// Returns the stripped records JSON string, or `{"error":"..."}` on failure.
#[cfg(feature = "extension-module")]
#[pyfunction]
#[pyo3(signature = (records_json, keep_columns_json = ""))]
fn values_only(records_json: &str, keep_columns_json: &str) -> String {
    use crate::embedded::core::parse;
    match parse::values_only(records_json, keep_columns_json) {
        Ok(records) => records,
        Err(e) => {% raw %}format!(r#"{{"error":{:?}}}"#, e){% endraw %},
    }
}

/// Replace non-direct field values with their annotated label string, then strip `__*` columns.
