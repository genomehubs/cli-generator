/// Perform a search query against the {{ site_display_name }} API.
///
/// When the configured `API_VERSION` is `"v3"`, POSTs to `/v3/search` and
/// returns a JSON flat-records array (suitable for `output::print_records`).
/// Otherwise falls back to a v2 GET request and returns the raw API response
/// body (TSV, JSON, or CSV per the `Accept` header).
pub fn search(
    index: super::indexes::Index,
    query: &str,
    fields: &[&str],
    size: usize,
    include_estimates: bool,
    accept: &str,
    opts: &SearchOptions,
) -> Result<String> {
    if is_v3() {
        let body = build_search_post_body(index, query, fields, size, include_estimates, opts, None);
        let url = format!("{API_BASE_URL}/v3/search");
        let raw = post_json(&url, &body)?;
        if opts.lineage_summary_config.is_null() {
            // parse_search_json returns a JSON flat-records array
            crate::embedded::core::parse::parse_search_json(&raw)
                .map_err(|e| anyhow::anyhow!("{e}"))
        } else {
            let config_json = opts.lineage_summary_config.to_string();
            crate::embedded::core::parse::parse_search_with_lineage_summary(&raw, &config_json)
                .map_err(|e| anyhow::anyhow!("{e}"))
        }
    } else {
        let url = search_url(index, query, fields, size, include_estimates, opts);
        let client = reqwest::blocking::Client::new();
        client
            .get(&url)
            .header("Accept", accept)
            .send()
            .with_context(|| format!("HTTP GET {url}"))?
            .error_for_status()
            .with_context(|| format!("non-2xx response from {url}"))?
            .text()
            .context("reading response body")
    }
}

/// Build the search URL without performing an HTTP request.
pub fn search_url(
    index: super::indexes::Index,
    query: &str,
    fields: &[&str],
    size: usize,
    include_estimates: bool,
    opts: &SearchOptions,
) -> String {
    let mut parts: Vec<String> = Vec::new();
    parts.push(format!("result={}", index.as_str()));
    parts.push(format!("includeEstimates={include_estimates}"));
    parts.push(format!("taxonomy={}", pct_encode(&opts.taxonomy)));
    if !query.is_empty() {
        parts.push(format!("query={}", pct_encode(query)));
    }
    if !fields.is_empty() {
        parts.push(format!("fields={}", pct_encode(&fields.join(","))));
    }
    if !opts.name_classes.is_empty() {
        parts.push(format!("names={}", pct_encode(&opts.name_classes.join(","))));
    }
    if !opts.lineage_ranks.is_empty() {
        parts.push(format!("ranks={}", pct_encode(&opts.lineage_ranks.join(","))));
    }
    // Add exclude parameters (indexed format for API arrays).
    for (i, field) in opts.exclude_ancestral.iter().enumerate() {
        parts.push(format!("excludeAncestral[{}]={}", i, pct_encode(field)));
    }
    for (i, field) in opts.exclude_descendant.iter().enumerate() {
        parts.push(format!("excludeDescendant[{}]={}", i, pct_encode(field)));
    }
    for (i, field) in opts.exclude_direct.iter().enumerate() {
        parts.push(format!("excludeDirect[{}]={}", i, pct_encode(field)));
    }
    for (i, field) in opts.exclude_missing.iter().enumerate() {
        parts.push(format!("excludeMissing[{}]={}", i, pct_encode(field)));
    }
    parts.push(format!("size={size}"));
    let offset = opts.page.saturating_sub(1) * size;
    parts.push(format!("offset={offset}"));
    if let Some(ref sort_by) = opts.sort_by {
        parts.push(format!("sortBy={}", pct_encode(sort_by)));
        parts.push(format!("sortOrder={}", pct_encode(&opts.sort_order)));
    }
    format!("{API_BASE}/search?{}", parts.join("&"))
}

