/// Perform a count query against the {{ site_display_name }} API.
///
/// Uses v3 POST when the configured `API_VERSION` is `"v3"`, otherwise falls
/// back to a v2 GET request.  Returns the hit count as a `u64`.
pub fn count(index: super::indexes::Index, query: &str, opts: &SearchOptions) -> Result<u64> {
    if is_v3() {
        count_v3(index, opts)
    } else {
        count_v2(index, query)
    }
}

/// Count using the v3 POST `/count` endpoint.
///
/// Builds the query object from `opts` — mirrors `build_search_post_body`.
fn count_v3(index: super::indexes::Index, opts: &SearchOptions) -> Result<u64> {
    let url = format!("{API_BASE_URL}/v3/count");
    let mut query_obj = serde_json::Map::new();
    query_obj.insert("index".to_string(), serde_json::json!(index.as_str()));
    if !opts.taxa.is_empty() {
        query_obj.insert("taxa".to_string(), serde_json::json!(opts.taxa));
        if opts.taxon_filter_type != "name" {
            query_obj.insert("taxon_filter_type".to_string(), serde_json::json!(opts.taxon_filter_type));
        }
    }
    if let Some(ref rank) = opts.rank_filter {
        query_obj.insert("rank".to_string(), serde_json::json!(rank));
    }
    if !opts.attributes.is_empty() {
        query_obj.insert("attributes".to_string(), serde_json::json!(opts.attributes));
    }
    let body = serde_json::json!({
        "query": serde_json::Value::Object(query_obj),
        "params": {
            "size": 0,
            "taxonomy": opts.taxonomy,
        },
    });
    let raw = post_json(&url, &body)?;
    let status = crate::embedded::core::parse::parse_response_status(&raw)
        .map_err(|e| anyhow::anyhow!("{e}"))?;
    Ok(status.hits)
}

/// Count using the legacy v2 GET `/count` endpoint.
fn count_v2(index: super::indexes::Index, query: &str) -> Result<u64> {
    let url = format!(
        "{API_BASE}/count?query={}&result={}",
        pct_encode(query),
        index.as_str(),
    );
    let body_text = reqwest::blocking::get(&url)
        .with_context(|| format!("HTTP GET {url}"))?
        .error_for_status()
        .with_context(|| format!("non-2xx response from {url}"))?
        .text()
        .context("reading count response body")?;
    let status = crate::embedded::core::parse::parse_response_status(&body_text)
        .map_err(|e| anyhow::anyhow!("{e}"))?;
    Ok(status.hits)
}

