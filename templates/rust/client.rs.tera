use anyhow::{Context, Result};

const API_BASE: &str = super::super::cli_meta::API_BASE;
const API_BASE_URL: &str = super::super::cli_meta::API_BASE_URL;
const API_VERSION: &str = super::super::cli_meta::API_VERSION;
const UI_BASE_URL: &str = super::super::cli_meta::UI_BASE_URL;

/// Percent-encode a string using RFC 3986 unreserved characters.
///
/// Unreserved chars (A–Z a–z 0–9 - _ . ~) are passed through; every other
/// byte is encoded as `%XX`.  This means spaces become `%20`, parentheses
/// become `%28`/`%29`, commas become `%2C`, etc.
fn pct_encode(s: &str) -> String {
    s.bytes()
        .map(|b| match b {
            b'A'..=b'Z' | b'a'..=b'z' | b'0'..=b'9' | b'-' | b'_' | b'.' | b'~' => {
                (b as char).to_string()
            }
            _ => format!("%{b:02X}"),
        })
        .collect()
}

/// Return true if the configured API version is v3.
#[inline]
fn is_v3() -> bool {
    API_VERSION == "v3"
}

/// POST a JSON body to `url` and return the response body as a string.
fn post_json(url: &str, body: &serde_json::Value) -> Result<String> {
    let client = reqwest::blocking::Client::new();
    client
        .post(url)
        .header("Content-Type", "application/json")
        .header("Accept", "application/json")
        .json(body)
        .send()
        .with_context(|| format!("HTTP POST {url}"))?
        .error_for_status()
        .with_context(|| format!("non-2xx response from {url}"))?
        .text()
        .context("reading response body")
}

/// Build the v3 POST body for a search or count request.
///
/// `search_after` is the opaque cursor from a previous `/search` response.
fn build_search_post_body(
    index: super::indexes::Index,
    _query: &str,
    fields: &[&str],
    size: usize,
    include_estimates: bool,
    opts: &SearchOptions,
    search_after: Option<&serde_json::Value>,
) -> serde_json::Value {
    // Build the structured query object — matches SearchQuery field layout.
    let mut query_obj = serde_json::Map::new();
    query_obj.insert("index".to_string(), serde_json::json!(index.as_str()));

    if !opts.taxa.is_empty() {
        query_obj.insert("taxa".to_string(), serde_json::json!(opts.taxa));
        if opts.taxon_filter_type != "name" {
            query_obj.insert("taxon_filter_type".to_string(), serde_json::json!(opts.taxon_filter_type));
        }
    }
    if let Some(ref rank) = opts.rank_filter {
        query_obj.insert("rank".to_string(), serde_json::json!(rank));
    }
    if !opts.attributes.is_empty() {
        query_obj.insert("attributes".to_string(), serde_json::json!(opts.attributes));
    }
    // fields: string array is normalised to [{name: …}] by the API deserializer.
    if !fields.is_empty() {
        query_obj.insert("fields".to_string(), serde_json::json!(fields));
    }
    if !opts.name_classes.is_empty() {
        query_obj.insert("names".to_string(), serde_json::json!(opts.name_classes));
    }
    if !opts.lineage_ranks.is_empty() {
        query_obj.insert("ranks".to_string(), serde_json::json!(opts.lineage_ranks));
    }
    // exclude_* belong in the query object (not params).
    if !opts.exclude_ancestral.is_empty() {
        query_obj.insert("exclude_ancestral".to_string(), serde_json::json!(opts.exclude_ancestral));
    }
    if !opts.exclude_descendant.is_empty() {
        query_obj.insert("exclude_descendant".to_string(), serde_json::json!(opts.exclude_descendant));
    }
    if !opts.exclude_direct.is_empty() {
        query_obj.insert("exclude_direct".to_string(), serde_json::json!(opts.exclude_direct));
    }
    if !opts.exclude_missing.is_empty() {
        query_obj.insert("exclude_missing".to_string(), serde_json::json!(opts.exclude_missing));
    }
    if !opts.lineage_summary_specs.is_empty() {
        query_obj.insert("lineage_rank_summary".to_string(), serde_json::json!(opts.lineage_summary_specs));
    }

    let mut params_obj = serde_json::json!({
        "size": size,
        "page": opts.page,
        "taxonomy": opts.taxonomy,
        "include_estimates": include_estimates,
        "sort_order": opts.sort_order,
    });
    if let Some(ref sort_by) = opts.sort_by {
        params_obj["sort_by"] = serde_json::Value::String(sort_by.clone());
    }

    let mut body = serde_json::json!({
        "query": serde_json::Value::Object(query_obj),
        "params": params_obj,
    });
    if let Some(sa) = search_after {
        body["search_after"] = sa.clone();
    }
    body
}

