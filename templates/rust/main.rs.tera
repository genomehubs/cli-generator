/// How to apply the taxon filter to the query.
#[derive(Debug, Clone, ValueEnum)]
enum TaxonFilter {
    /// Match the exact taxon name (`tax_name`).
    Name,
    /// Match all descendants (`tax_tree`).
    Tree,
    /// Match all ancestors (`tax_lineage`).
    Lineage,
}

#[derive(Parser)]
#[command(name = cli_meta::NAME, about = cli_meta::ABOUT, version)]
struct Cli {
    #[command(subcommand)]
    command: Commands,
}

#[derive(Subcommand)]
enum Commands {
{% for index in indexes %}
    /// Query the `{{ index.name }}` index.
    {{ index.name | capitalize }} {
        #[command(subcommand)]
        subcommand: {{ index.name | capitalize }}Commands,
    },
{% endfor %}
    /// Convert a report response (or PlotSpec) to Vega-Lite JSON, SVG, or PNG.
    ///
    /// Reads a JSON report response from stdin or `--input`.
    /// Outputs to stdout or `--output`.  Pipe the output of a
    /// `report --include-plot-spec` command directly to `plot`.
    ///
    /// SVG/PNG output requires building with: `cargo build --features vl-convert`
    Plot {
        /// Output format: json (Vega-Lite, default), svg, or png.
        #[arg(long, default_value = "json", value_parser = ["json", "svg", "png"])]
        format: String,

        /// Input file path (reads from stdin if omitted).
        #[arg(long, short = 'i')]
        input: Option<std::path::PathBuf>,

        /// Output file path (writes to stdout if omitted).
        #[arg(long, short = 'o')]
        output: Option<std::path::PathBuf>,
    },

    /// Run a positional report query against `POST /api/v3/positional`.
    ///
    /// All four sub-types (oxford, ribbon, painting, circos) share this command
    /// and the same flag set.  Select the sub-type with `--report`.
    Positional {
        /// Report sub-type.
        #[arg(long, value_parser = ["oxford", "ribbon", "painting", "circos"], default_value = "oxford")]
        report: String,

        /// Shared feature identifier field (e.g. `busco_gene`, `metazoa_odb10-busco-gene`).
        #[arg(long = "group-by")]
        group_by: String,

        /// Assembly accessions, comma-separated (e.g. `GCA_905147045.1,GCA_902806685.2`).
        #[arg(long, value_delimiter = ',')]
        assemblies: Vec<String>,

        /// Feature type to filter on.  Defaults to `--group-by` when omitted.
        #[arg(long = "feature-type")]
        feature_type: Option<String>,

        /// Window size in base-pairs for regional grouping.
        #[arg(long = "window-size")]
        window_size: Option<u64>,

        /// Disable auto-reorientation of comparison sequences.
        #[arg(long = "no-reorient")]
        no_reorient: bool,

        /// Maximum features to fetch from the index.
        #[arg(long = "max-features", default_value_t = 10_000)]
        max_features: usize,

        /// Category field for colour coding (e.g. `busco_status`, `merian_unit`).
        #[arg(long)]
        cat: Option<String>,

        /// Category axis options string.
        #[arg(long = "cat-opts")]
        cat_opts: Option<String>,

        /// Attribute filter as a JSON object (repeatable).
        ///
        /// Each value must be a JSON object matching AttributeFilter.  Example:
        /// --filter-json '{"field":"gc","operator":"gt","value":"0.45","target":"sequence"}'
        #[arg(long = "filter-json")]
        filter_json: Vec<String>,

        /// Region computation config as a JSON object.
        ///
        /// Example: --regions '{"cat":"merian_unit","bounds":"midpoints"}'
        #[arg(long)]
        regions: Option<String>,

        /// Maximum connections per group cap for M:N feature mappings.
        #[arg(long = "max-connections-per-group")]
        max_connections_per_group: Option<usize>,

        /// Output format.
        #[arg(long, value_enum, default_value = "json")]
        format: generated::output::OutputFormat,
    },

    /// Compute a positional report (oxford/ribbon/painting) from local feature files (no API call).
    ///
    /// Each assembly requires a feature `full_table.tsv` (BUSCO format) supplied as two arguments:
    /// ASSEMBLY_ID and PATH.  Sequence lengths are inferred from the feature file unless `--fai` or
    /// `--lengths` is provided.  Multiple `--features` flags give the assemblies in order.
    ///
    /// Example (oxford, two assemblies):
    ///   local-positional --features asm1 /path/to/asm1/full_table.tsv \
    ///                    --features asm2 /path/to/asm2/full_table.tsv
    LocalPositional {
        /// Feature file for one assembly (BUSCO format): ASSEMBLY_ID PATH (repeatable; order matters).
        #[arg(long = "features", value_names = ["ASSEMBLY_ID", "PATH"], num_args = 2, required = true)]
        features: Vec<String>,

        /// FAI index for an assembly: ASSEMBLY_ID PATH (optional, repeatable).
        ///
        /// Overrides feature-derived sequence lengths for the named assembly.
        #[arg(long = "fai", value_names = ["ASSEMBLY_ID", "PATH"], num_args = 2)]
        fai: Vec<String>,

        /// Two-column lengths TSV for an assembly: ASSEMBLY_ID PATH (optional, repeatable).
        ///
        /// Alternative to --fai; used when a .fai index is not available.
        #[arg(long = "lengths", value_names = ["ASSEMBLY_ID", "PATH"], num_args = 2)]
        lengths: Vec<String>,

        /// Two-column name→category TSV for an assembly: ASSEMBLY_ID PATH (optional, repeatable).
        ///
        /// Overrides the category field for named features in the given assembly.
        #[arg(long = "cat-file", value_names = ["ASSEMBLY_ID", "PATH"], num_args = 2)]
        cat_file: Vec<String>,

        /// Report sub-type.
        #[arg(long, value_parser = ["oxford", "ribbon", "painting"], default_value = "oxford")]
        report: String,

        /// Category field for colour coding (reads from feature `status` column if omitted).
        #[arg(long)]
        cat: Option<String>,

        /// Window size in base-pairs for windowed painting.
        #[arg(long = "window-size")]
        window_size: Option<u64>,

        /// Disable auto-reorientation of comparison sequences.
        #[arg(long = "no-reorient")]
        no_reorient: bool,

        /// Maximum connections per group cap for M:N feature mappings.
        #[arg(long = "max-connections-per-group", default_value_t = 0)]
        max_connections_per_group: usize,

        /// Include only features whose category matches this value (repeatable).
        #[arg(long = "include-status")]
        include_status: Vec<String>,

        /// Exclude features whose category matches this value (repeatable).
        #[arg(long = "exclude-status")]
        exclude_status: Vec<String>,

        /// Compute a region summary layer on the output.
        ///
        /// How region boundaries are placed: `feature_ends` (default) keeps
        /// boundaries at feature positions; `midpoints` expands them to the
        /// midpoint between adjacent features.
        #[arg(long = "region-bounds", value_parser = ["feature_ends", "midpoints"])]
        region_bounds: Option<String>,

        /// Minimum number of consecutive same-category features required to
        /// define a region.  Shorter runs are treated as interruptions within
        /// an adjacent region (if within `--region-tolerance`) or discarded.
        /// Setting this to e.g. 5 means a single stray category cannot start
        /// its own region.  Default: 1.
        #[arg(long = "region-threshold")]
        region_threshold: Option<usize>,

        /// Maximum number of consecutive non-matching features that can be
        /// absorbed as labelled interruptions within a region before the region
        /// is considered to have ended.  With `--region-tolerance 1` a single
        /// cat-B feature in a run of cat-A features is absorbed and the A
        /// region spans across it.  Default: 0 (any non-matching feature
        /// breaks the region).
        #[arg(long = "region-tolerance")]
        region_tolerance: Option<usize>,

        /// Output file path (writes to stdout if omitted).
        #[arg(long, short = 'o')]
        output: Option<std::path::PathBuf>,
    },

    /// Build a plot spec from a local TSV/CSV file (no API call).
    ///
    /// Reads a delimited file, builds a PlotSpec, and writes Vega-Lite JSON,
    /// SVG, or PNG to stdout or `--output`.  File format is auto-detected from
    /// the extension (`.tsv`/`.tab` → TSV, `.csv` → CSV; unknown defaults to TSV).
    ///
    /// SVG/PNG output requires building with: `cargo build --features vl-convert`
    LocalReport {
        /// Input file path (reads from stdin if omitted).
        #[arg(long, short = 'i')]
        input: Option<std::path::PathBuf>,

        /// Report type: histogram, scatter, bar.
        #[arg(long, default_value = "histogram")]
        report_type: String,

        /// Column to use as the X axis.
        #[arg(long)]
        x: Option<String>,

        /// Column to use as the Y axis (scatter only).
        #[arg(long)]
        y: Option<String>,

        /// Display options as a JSON string (e.g. `'{"title":"My plot","width":900}'`).
        #[arg(long)]
        display: Option<String>,

        /// Field delimiter override (e.g. `\t` or `,`).
        #[arg(long)]
        delimiter: Option<char>,

        /// Output format: json (Vega-Lite, default), svg, or png.
        #[arg(long, default_value = "json", value_parser = ["json", "svg", "png"])]
        format: String,

        /// Output file path (writes to stdout if omitted).
        #[arg(long, short = 'o')]
        output: Option<std::path::PathBuf>,
    },
}

