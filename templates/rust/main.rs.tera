        /// Additional raw query string ANDed with all other filters.
        #[arg(long, default_value = "")]
        query: String,

        /// Maximum number of results to return per page.
        #[arg(long, default_value = "50")]
        size: usize,

        /// Page number for paginated results (1-based).
        #[arg(long, default_value_t = 1)]
        page: usize,

        /// Include ancestrally estimated values (use --include-estimates=false to disable).
        #[arg(long, default_value_t = true, action = clap::ArgAction::Set)]
        include_estimates: bool,

        /// Taxonomy source to use (default: ncbi).
        #[arg(long, default_value = "ncbi")]
        taxonomy: String,

        /// Lineage rank columns to include, comma-separated (e.g. `genus,family,order`).
        #[arg(long = "lineage-ranks", value_delimiter = ',')]
        lineage_ranks: Vec<String>,

        /// Taxon name classes to include, comma-separated (e.g. `common_name,synonym`).
        #[arg(long = "name-classes", value_delimiter = ',')]
        name_classes: Vec<String>,

        /// Print the API URL and exit without fetching.
        #[arg(long)]
        url: bool,

        /// Print a human-readable description of the query instead of executing it.
        #[arg(long)]
        describe: bool,

        /// Verbose description (detailed breakdown).
        #[arg(long)]
        verbose: bool,

        /// Output format.
        #[arg(long, value_enum, default_value = "tsv")]
        format: generated::output::OutputFormat,

