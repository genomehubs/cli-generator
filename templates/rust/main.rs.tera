/// Dispatch a parsed command to the appropriate generated function.
fn run(cli: Cli) -> anyhow::Result<()> {
    match cli.command {
{% for index in indexes %}
        Commands::{{ index.name | capitalize }} { subcommand } => match subcommand {
            {{ index.name | capitalize }}Commands::Search { taxon, taxon_filter, query, filter, rank, sort, size, page, include_estimates, taxonomy, lineage_ranks, name_classes, url, describe, verbose, format, flags } => {
                if flags.list_field_groups {
                    for (name, short, desc) in generated::cli_flags::{{ index.name | capitalize }}Flags::list_groups() {
                        match short {
                            Some(c) => println!("{name:<20} [{c}]  {desc}"),
                            None    => println!("{name:<20}       {desc}"),
                        }
                    }
                    return Ok(());
                }

                // Build the taxon clause from --taxon and --taxon-filter.
                let taxon_clause = taxon.as_deref().map(|t| match taxon_filter {
                    TaxonFilter::Name     => format!("tax_name({t})"),
                    TaxonFilter::Tree     => format!("tax_tree({t})"),
                    TaxonFilter::Lineage  => format!("tax_lineage({t})"),
                });

                // Convert --filter FIELD OP VALUE triples into expression fragments.
                let filter_fragments: Vec<String> = filter
                    .chunks(3)
                    .filter_map(|chunk| {
                        if chunk.len() < 3 {
                            return None;
                        }
                        let op_symbol = match chunk[1].as_str() {
                            "eq" | "==" | "=" => "=",
                            "ne" | "!="       => "!=",
                            "gt" | ">"        => ">",
                            "ge" | ">="       => ">=",
                            "lt" | "<"        => "<",
                            "le" | "<="       => "<=",
                            other             => other,
                        };
                        Some(format!("{}{}{}", chunk[0], op_symbol, chunk[2]))
                    })
                    .collect();

                // Combine all query parts: taxon, rank, raw --query, --filter expressions.
                let full_query = {
                    let mut parts: Vec<String> = Vec::new();
                    if let Some(tc) = taxon_clause {
                        parts.push(tc);
                    }
                    if let Some(ref r) = rank {
                        parts.push(format!("tax_rank({r})"));
                    }
                    if !query.is_empty() {
                        parts.push(query.clone());
                    }
                    parts.extend(filter_fragments);
                    parts.join(" AND ")
                };

                // Parse --sort into field name and direction.
                let (sort_by_opt, sort_order_str) = match sort.as_deref() {
                    None => (None::<String>, "asc".to_string()),
                    Some(s) => match s.split_once(':') {
                        Some((field, dir)) => (Some(field.to_string()), dir.to_string()),
                        None               => (Some(s.to_string()), "asc".to_string()),
                    },
                };

                let opts = generated::client::SearchOptions {
                    lineage_ranks,
                    name_classes,
                    sort_by: sort_by_opt,
                    sort_order: sort_order_str,
                    page,
                    taxonomy,
                };

                // If describe flag is set, output human-readable description instead
                if describe {
                    let description = describe_query(
                        &full_query,
                        &generated::field_meta::{{ index.name | upper }}_FIELD_META,
                        verbose,
                    )?;
                    println!("{description}");
                    return Ok(());
                }

                // Normal search execution
                let owned_fields = flags.all_fields();
                let fields: Vec<&str> = owned_fields.iter().map(|s: &String| s.as_str()).collect();
                let accept = format.accept_header();
                if url {
                    let query_url = generated::client::search_url(
                        generated::indexes::Index::{{ index.name | capitalize }},
                        &full_query,
                        &fields,
                        size,
                        include_estimates,
                        &opts,
                    );
                    println!("{query_url}");
                    return Ok(());
                }
                let body = generated::client::search(
                    generated::indexes::Index::{{ index.name | capitalize }},
                    &full_query,
                    &fields,
                    size,
                    include_estimates,
                    accept,
                    &opts,
                )?;
                generated::output::print_output(&body, format)?;
            }
            {{ index.name | capitalize }}Commands::Count { query } => {
                let n = generated::client::count(
                    generated::indexes::Index::{{ index.name | capitalize }},
                    &query,
                )?;
                println!("{n}");
            }
            {{ index.name | capitalize }}Commands::Lookup { search_term, size, format } => {
                let body = generated::client::lookup(
                    generated::indexes::Index::{{ index.name | capitalize }},
                    &search_term,
                    size,
                )?;
                generated::output::print_output(&body, format)?;
            }
        },
{% endfor %}
    }
    Ok(())
}

/// Parse a query string and generate a human-readable description.
fn describe_query(
    query_str: &str,
    field_meta_map: &phf::Map<&'static str, FieldMeta>,
    verbose: bool,
) -> anyhow::Result<String> {
    use std::collections::HashMap;
    use {{ sdk_name }}::embedded::core;

    // Try to parse as a YAML SearchQuery; if that fails, treat as a raw query string
    let query: core::query::SearchQuery = {
        // Try full YAML parsing first
        core::query::SearchQuery::from_yaml(query_str).or_else(|_| {
            // Fall back: wrap the query string in a minimal valid YAML structure
            // Treat it as a taxon name in the attributes
            let yaml = format!(
                "index: taxon\nattributes:\n  - name: scientific_name\n    operator: eq\n    value: \"{}\"",
                query_str
            );
            core::query::SearchQuery::from_yaml(&yaml)
        })?
    };

    // Convert phf::Map to HashMap for QueryDescriber
    // (QueryDescriber only needs display_name, so we create minimal FieldDef objects)
    let mut field_metadata: HashMap<String, core::fetch::FieldDef> = HashMap::new();
    for (name, _meta) in field_meta_map.entries() {
        field_metadata.insert(
            name.to_string(),
            core::fetch::FieldDef {
                name: name.to_string(),
                display_group: None,
                display_name: None, // Could be populated from API in the future
                description: None,
                field_type: None,
                constraint: None,
                display_level: None,
                synonyms: vec![],
                processed_type: None,
                traverse_direction: None,
                summary: vec![],
            },
        );
    }

    // Create describer and generate description
    let describer = core::describe::QueryDescriber::new(field_metadata);
    Ok(if verbose {
        describer.describe_verbose(&query)
    } else {
        describer.describe_concise(&query)
    })
}
