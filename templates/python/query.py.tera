            saved_lrs = self._lineage_rank_summary
            self._lineage_rank_summary = specs
            try:
                raw = self.search()
            finally:
                self._lineage_rank_summary = saved_lrs
            raw_str = json.dumps(raw) if isinstance(raw, dict) else raw
            config_json = json.dumps(lineage_summary)
            return list(json.loads(_ext.parse_search_with_lineage_summary(raw_str, config_json)))
        raw = self.search()
        raw_str = json.dumps(raw) if isinstance(raw, dict) else raw
        return list(json.loads(_ext.parse_search_json(raw_str)))

