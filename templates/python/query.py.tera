    def field_modifiers(self) -> list[str]:
        """Return the ``__modifier`` column names implied by any field requests with modifiers.

        Pass the return value as ``keep_columns_json`` to ``values_only`` or
        ``annotated_values`` to preserve explicitly-requested modifier columns
        (e.g. ``assembly_span__min`` from an ``addField("assembly_span:min")``
        request).
        """
