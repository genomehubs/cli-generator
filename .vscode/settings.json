{
  // ── Tera templates — disable ALL formatting to prevent indentation corruption
  // ────────────────────────────────────────────────────────────────────────────
  // Without this, rust-analyzer and black treat .tera files as Rust/Python and
  // corrupt the indentation.  Map to plaintext so no formatter runs on them.
  "files.associations": {
    "*.tera": "plaintext"
  },

  // ── Rust ──────────────────────────────────────────────────────────────────
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true
  },
  // Run clippy (not just cargo check) on save for richer diagnostics.
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.extraArgs": ["--", "-D", "warnings"],

  // ── Python ────────────────────────────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      // Triggers the isort extension to sort imports on every save.
      "source.organizeImports": "explicit"
    }
  },
  "black-formatter.args": ["--line-length", "120"],
  "isort.args": ["--profile", "black", "--line-length", "120"],

  // ── TOML ──────────────────────────────────────────────────────────────────
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.formatOnSave": true
  },

  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.rulers": [120],
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "chat.tools.terminal.autoApprove": {
    "cargo test": true,
    "pyright": true,
    "/^python -m pyright python/ tests/python/ 2>&1$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
