{
  "openapi": "3.1.0",
  "info": {
    "title": "genomehubs-api",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/v3/count": {
      "post": {
        "tags": [
          "routes::count"
        ],
        "operationId": "post_count",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CountRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Count result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v3/indices": {
      "get": {
        "tags": [
          "routes::indices"
        ],
        "operationId": "get_indices_openapi",
        "responses": {
          "200": {
            "description": "Cached indices",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndicesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v3/resultFields": {
      "get": {
        "tags": [
          "routes::result_fields"
        ],
        "operationId": "get_result_fields",
        "parameters": [
          {
            "name": "result",
            "in": "query",
            "description": "Result type (taxon|assembly|sample)",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Field metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultFieldsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v3/status": {
      "get": {
        "tags": [
          "routes::status"
        ],
        "operationId": "get_status",
        "responses": {
          "200": {
            "description": "Health status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v3/taxonomicRanks": {
      "get": {
        "tags": [
          "routes::taxonomic_ranks"
        ],
        "operationId": "get_taxonomic_ranks_openapi",
        "responses": {
          "200": {
            "description": "Cached taxonomic ranks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RanksResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v3/taxonomies": {
      "get": {
        "tags": [
          "routes::taxonomies"
        ],
        "operationId": "get_taxonomies_openapi",
        "responses": {
          "200": {
            "description": "Cached taxonomies",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaxonomiesResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiStatus": {
        "type": "object",
        "description": "Uniform status block present in every v3 API response.\n\nMetadata-only endpoints (taxonomies, ranks, indices) omit `hits` and `took`.\nQuery endpoints always populate all four fields.",
        "required": [
          "success"
        ],
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "hits": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "success": {
            "type": "boolean"
          },
          "took": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "CountRequest": {
        "type": "object",
        "required": [
          "query_yaml",
          "params_yaml"
        ],
        "properties": {
          "params_yaml": {
            "type": "string",
            "description": "YAML string describing the QueryParams"
          },
          "query_yaml": {
            "type": "string",
            "description": "YAML string describing the SearchQuery"
          }
        }
      },
      "CountResponse": {
        "type": "object",
        "required": [
          "status",
          "url"
        ],
        "properties": {
          "status": {
            "$ref": "#/components/schemas/ApiStatus"
          },
          "url": {
            "type": "string",
            "description": "The executed ES URL"
          }
        }
      },
      "FieldMeta": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "processed_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "IndicesResponse": {
        "type": "object",
        "required": [
          "status",
          "indices"
        ],
        "properties": {
          "indices": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_updated": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/ApiStatus"
          }
        }
      },
      "RanksResponse": {
        "type": "object",
        "required": [
          "status",
          "ranks"
        ],
        "properties": {
          "last_updated": {
            "type": [
              "string",
              "null"
            ]
          },
          "ranks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "$ref": "#/components/schemas/ApiStatus"
          }
        }
      },
      "ResultFieldsResponse": {
        "type": "object",
        "required": [
          "status",
          "fields",
          "identifiers",
          "hub",
          "release",
          "source"
        ],
        "properties": {
          "fields": {},
          "hub": {
            "type": "string"
          },
          "identifiers": {},
          "release": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/ApiStatus"
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "required": [
          "status",
          "ready",
          "supported"
        ],
        "properties": {
          "last_updated": {
            "type": [
              "string",
              "null"
            ]
          },
          "ready": {
            "type": "boolean"
          },
          "status": {
            "$ref": "#/components/schemas/ApiStatus"
          },
          "supported": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "TaxonomiesResponse": {
        "type": "object",
        "required": [
          "status",
          "taxonomies"
        ],
        "properties": {
          "last_updated": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/ApiStatus"
          },
          "taxonomies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}